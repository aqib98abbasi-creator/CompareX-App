# ============================================================================
# CompareX Environment Variables
# Copy this file to .env and fill in your values.
# All keys use the EXPO_PUBLIC_ prefix to be accessible in the app bundle.
# ============================================================================

# --- Supabase ---
# Create a project at https://supabase.com (free tier)
# Find these values in: Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Cloudflare Worker ---
# Deploy workers/api-proxy.ts to Cloudflare Workers (free tier)
EXPO_PUBLIC_WORKER_URL=https://comparex-api-proxy.your-subdomain.workers.dev

# --- PostHog Analytics ---
# Sign up at https://posthog.com (free tier: 1M events/month)
EXPO_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry Error Monitoring ---
# Sign up at https://sentry.io (free tier: 5K errors/month)
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# --- GitHub Catalog URL (optional) ---
# Raw URL to your catalog.json hosted on GitHub
EXPO_PUBLIC_CATALOG_URL=https://raw.githubusercontent.com/YOUR_USER/YOUR_REPO/main/public/catalog.json

# --- Google AdMob ---
# Create an AdMob account at https://admob.google.com (free)
# Create a Banner ad unit, copy the Ad Unit ID
# Also update app.json with your AdMob App IDs (androidAppId / iosAppId)
EXPO_PUBLIC_ADMOB_ID=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
